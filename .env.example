# ==========================================================================
# AutoGPT Platform on Render — deployer-supplied values
# ==========================================================================
# Set on Render in the Dashboard (Blueprint prompts / env groups), NOT read
# from this file. Copy to `.env` only for LOCAL docker-compose dev.
# `.env` is gitignored — never commit real secrets.
#
# To develop locally instead of deploying, see local.md (uses .env.default).
# ==========================================================================


# ==========================================================================
# REQUIRED — a working Render deploy needs all of these
# ==========================================================================

# --- LLM key (AI blocks + copilot chat) -------------------------------------
# The deploy technically succeeds with none set, but AI blocks and copilot chat
# produce nothing until one is present — so this is required in practice.
# Pick a copilot transport (prefix CHAT_; defaults to OpenRouter):
#   OpenRouter (default) | OPEN_ROUTER_API_KEY  (falls back to OPENAI_API_KEY)
#   Direct Anthropic     | CHAT_USE_OPENROUTER=false + ANTHROPIC_API_KEY
# AI blocks read ANTHROPIC_API_KEY / OPENAI_API_KEY directly.
# On Render: put these in a Dashboard env group `autogpt-platform-llm` linked to
# rest-server + the executor Workflow (see README); do NOT add to render.yaml.
OPEN_ROUTER_API_KEY=                  # OpenRouter key (default copilot transport)
ANTHROPIC_API_KEY=                    # direct copilot + Claude AI blocks
OPENAI_API_KEY=                       # OpenAI blocks + OpenRouter fallback
CHAT_USE_OPENROUTER=true              # false = copilot direct to Anthropic

# --- ENCRYPTION_KEY (stored-credential encryption) --------------------------
# Deployer-supplied (Render's generateValue isn't a valid Fernet key). Generate
# ONE and paste the IDENTICAL value into every backend service + the executor
# Workflow, or stored creds become undecryptable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Executor Workflow dispatch ---------------------------------------------
# Graph execution runs on Render Workflows (created by hand — Blueprints can't
# declare Workflows). Set on rest-server + scheduler-server.
EXECUTION_BACKEND=workflows
RENDER_API_KEY=                       # Render workspace API key (dispatch to the Workflow)
RENDER_WORKFLOW_SLUG=                 # slug of the manually-created executor Workflow

# --- Public origins (fill in once services have URLs; rebuild frontend after) -
FRONTEND_ORIGIN=https://your-frontend.onrender.com
REST_ORIGIN=https://your-rest-server.onrender.com
PLATFORM_BASE_URL=${REST_ORIGIN}
FRONTEND_BASE_URL=${FRONTEND_ORIGIN}
BACKEND_CORS_ALLOW_ORIGINS=["https://your-frontend.onrender.com"]

# --- frontend (NEXT_PUBLIC_* are build-time; rebuild after changing) --------
NEXT_PUBLIC_AGPT_SERVER_URL=${REST_ORIGIN}/api
NEXT_PUBLIC_AGPT_WS_SERVER_URL=wss://your-websocket-server.onrender.com/ws
NEXT_PUBLIC_SUPABASE_URL=${FRONTEND_ORIGIN}          # the frontend's OWN origin
NEXT_PUBLIC_SUPABASE_ANON_KEY=                       # anon JWT signed with JWT_VERIFY_KEY
NEXT_PUBLIC_FRONTEND_BASE_URL=${FRONTEND_ORIGIN}

# --- GoTrue auth (origins + SMTP for signup/reset email) --------------------
# No SMTP? Set GOTRUE_MAILER_AUTOCONFIRM=true on gotrue to skip email confirm.
GOTRUE_SITE_URL=${FRONTEND_ORIGIN}
GOTRUE_API_EXTERNAL_URL=${FRONTEND_ORIGIN}
GOTRUE_URI_ALLOW_LIST=https://your-frontend.onrender.com/**
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=AutoGPT Platform
GOTRUE_SMTP_ADMIN_EMAIL=

# Auto-generated by Render (do NOT set): JWT_VERIFY_KEY, UNSUBSCRIBE_SECRET_KEY.


# ==========================================================================
# OPTIONAL
# ==========================================================================

# --- Google OAuth (leave ENABLED=false to skip) -----------------------------
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://your-frontend.onrender.com/auth/v1/callback

# --- Redis (local docker-compose parity; Render sets these via render.yaml) --
REDIS_PORT=6379
REDIS_CLUSTER_MODE=false
