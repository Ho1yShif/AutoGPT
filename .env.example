# ==========================================================================
# AutoGPT Platform on Render — deployer-supplied values
# ==========================================================================
# This file documents the secrets/URLs you enter when deploying render.yaml.
# On Render these are set in the Dashboard (Blueprint prompts / env group),
# NOT read from this file. Copy to `.env` only for LOCAL docker-compose dev.
# `.env` is gitignored — never commit real secrets.
#
# Auto-generated by Render (env group `autogpt-platform-secrets`, do NOT set
# here): JWT_VERIFY_KEY, ENCRYPTION_KEY, UNSUBSCRIBE_SECRET_KEY.
# ==========================================================================

# --- Public origins (know these once the services get their URLs) ----------
# rest-server, websocket-server and frontend each get an <name>.onrender.com
# URL (or your custom domain). Fill these in, then trigger a frontend rebuild
# (NEXT_PUBLIC_* are inlined at build time).
FRONTEND_ORIGIN=https://your-frontend.onrender.com
REST_ORIGIN=https://your-rest-server.onrender.com

# --- rest-server / scheduler-server -----------------------------------------
RENDER_API_KEY=                       # Render workspace API key (Workflows dispatch)
RENDER_WORKFLOW_SLUG=                 # slug of the manually-created executor Workflow
PLATFORM_BASE_URL=${REST_ORIGIN}
FRONTEND_BASE_URL=${FRONTEND_ORIGIN}
BACKEND_CORS_ALLOW_ORIGINS=["https://your-frontend.onrender.com"]

# --- frontend (NEXT_PUBLIC_* are build-time; rebuild after changing) --------
NEXT_PUBLIC_AGPT_SERVER_URL=${REST_ORIGIN}/api
NEXT_PUBLIC_AGPT_WS_SERVER_URL=wss://your-websocket-server.onrender.com/ws
NEXT_PUBLIC_SUPABASE_URL=${FRONTEND_ORIGIN}          # the frontend's OWN origin
NEXT_PUBLIC_SUPABASE_ANON_KEY=                       # anon JWT signed with JWT_VERIFY_KEY
NEXT_PUBLIC_FRONTEND_BASE_URL=${FRONTEND_ORIGIN}

# --- GoTrue (auth) ----------------------------------------------------------
GOTRUE_SITE_URL=${FRONTEND_ORIGIN}
GOTRUE_API_EXTERNAL_URL=${FRONTEND_ORIGIN}
GOTRUE_URI_ALLOW_LIST=https://your-frontend.onrender.com/**

# GoTrue SMTP (required for email confirm / password reset / email change) ---
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=AutoGPT Platform
GOTRUE_SMTP_ADMIN_EMAIL=

# GoTrue Google OAuth (optional — leave ENABLED=false to skip) ---------------
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://your-frontend.onrender.com/auth/v1/callback

# --- Executor Workflow (set in the Dashboard when creating the Workflow) ----
# Must match the env group value exactly, or stored creds become undecryptable:
#   ENCRYPTION_KEY  (copy from the autogpt-platform-secrets group after deploy)

# --- Redis (Render Key Value defaults; for local docker-compose parity) -----
REDIS_PORT=6379
REDIS_CLUSTER_MODE=false
